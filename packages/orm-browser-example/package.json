{
  "name": "@d7/orm-browser-example",
  "version": "1.0.1-alpha.14",
  "description": "D7 ORM Data Browser example",
  "type": "commonjs",
  "private": true,
  "main": "./dist/cjs/main.js",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": "https://github.com/marcj/d7",
  "author": "Marc J. Schmidt <marc@marcjschmidt.de>",
  "license": "MIT",
  "dependencies": {
    "@d7/mongo": "^1.0.1",
    "@d7/orm-browser": "^1.0.1",
    "@d7/mysql": "^1.0.1",
    "@d7/orm": "^1.0.1",
    "@d7/postgres": "^1.0.1",
    "@d7/sqlite": "^1.0.1",
    "@d7/type": "^1.0.1"
  },
  "devDependencies": {
    "reflect-metadata": "^0.1.13"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    },
    "moduleNameMapper": {
      "(.+)\\.js": "$1"
    },
    "testMatch": [
      "**/tests/**/*.spec.ts"
    ]
  }
}
