{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "moduleResolution": "node",
    "target": "es2020",
    "module": "CommonJS",
    "esModuleInterop": true,
    "baseUrl": ".",
    "outDir": "./dist/cjs",
    "rootDir": "./src",
    "declaration": true,
    "composite": true,
    "lib": ["es2020", "es2022.error"],
    "skipLibCheck": true,
    "types": ["node"]
  },
  "reflection": true,
  "include": ["src"],
  "exclude": ["tests", "dist", "node_modules"],
  "references": [{"path": "../runtime/tsconfig.json"},{"path": "../reflection/tsconfig.json"},{"path": "../codec/tsconfig.json"}]
}
