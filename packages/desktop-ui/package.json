{
  "name": "@deepkit/desktop-ui",
  "version": "2.0.0",
  "description": "Library for desktop UI widgets in Angular 10+",
  "keywords": [
    "Desktop",
    "UI",
    "MacOS"
  ],
  "bin": {
    "dui-create-font": "./bin/create-font.js"
  },
  "repository": "https://github.com/deepkit/deepkit-framework",
  "author": "Marc J. Schmidt <marc@marcjschmidt.de>",
  "license": "MIT",
  "sideEffects": false,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    "./src/scss/all.scss": {
      "default": "./src/scss/all.scss"
    },
    "./src/scss/icon.scss": {
      "default": "./src/scss/icon.scss"
    },
    "./src/scss/reset.scss": {
      "default": "./src/scss/reset.scss"
    },
    "./docs.json": {
      "default": "./src/assets/docs.json"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/fesm2022/deepkit-desktop-ui.mjs"
    }
  },
  "scripts": {
    "font": "node bin/create-font.js",
    "build": "npm run font && npm run docjson && rm -rf .angular && ng-packagr --config tsconfig.prod.json && rm dist/.npmignore",
    "watch": "ng-packagr --config tsconfig.prod.json --watch",
    "docjson": "typedoc --json docs.json --out .typedoc-html --options ../../typedoc.js --plugin ../../typedoc.decorators.js src/index.ts && cp docs.json src/assets/docs.json && rm -rf .typedoc-html",
    "prepublishOnly": "webpack && node bin/create-font.js"
  },
  "browserslist": [
    "last 2 Chrome versions"
  ],
  "dependencies": {
    "on-change": "4.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@angular-devkit/build-angular": "20.3.15",
    "@angular/animations": "20.3.16",
    "@angular/cdk": "20.2.14",
    "@angular/cli": "20.3.15",
    "@angular/common": "20.3.16",
    "@angular/compiler": "20.3.16",
    "@angular/compiler-cli": "20.3.16",
    "@angular/core": "20.3.16",
    "@angular/forms": "20.0.4",
    "@angular/platform-browser": "20.3.16",
    "@angular/platform-browser-dynamic": "20.3.16",
    "@angular/router": "20.3.16",
    "@deepkit/core": "^2.0.0",
    "@deepkit/core-rxjs": "^2.0.0",
    "@deepkit/event": "^2.0.0",
    "@deepkit/type": "^2.0.0"
  },
  "devDependencies": {
    "@deepkit/core": "^2.0.0",
    "@deepkit/core-rxjs": "^2.0.0",
    "@deepkit/event": "^2.0.0",
    "@deepkit/type": "^2.0.0",
    "@types/fs-extra": "8.1.5",
    "@types/node": "22.19.21",
    "fs-extra": "8.1.0",
    "ng-packagr": "20.3.2",
    "rxjs": "7.8.2",
    "svg2ttf": "4.3.0",
    "svgicons2svgfont": "9.2.0",
    "ts-loader": "9.6.0",
    "ttf2woff": "2.0.2",
    "webpack": "5.107.2",
    "webpack-cli": "5.1.4"
  },
  "gitHead": "c1d3a8fba42c89448ee51a0fa42d1b7281edd86c"
}
