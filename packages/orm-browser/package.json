{
  "name": "@d7/orm-browser",
  "version": "1.0.19",
  "description": "ORM Browser",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "repository": "https://github.com/marcj/d7",
  "author": "Marc J. Schmidt <marc@marcjschmidt.de>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json"
  },
  "peerDependencies": {
    "@d7/app": "^1.0.1",
    "@d7/broker": "^1.0.1",
    "@d7/bson": "^1.0.1",
    "@d7/core": "^1.0.1",
    "@d7/framework": "^1.0.1",
    "@d7/http": "^1.0.1",
    "@d7/injector": "^1.0.1",
    "@d7/logger": "^1.0.1",
    "@d7/orm": "^1.0.1",
    "@d7/rpc": "^1.0.1",
    "@d7/type": "^1.0.1"
  },
  "dependencies": {
    "@d7/orm-browser-gui": "^1.0.19"
  },
  "devDependencies": {
    "@d7/app": "^1.0.19",
    "@d7/broker": "^1.0.19",
    "@d7/bson": "^1.0.19",
    "@d7/core": "^1.0.19",
    "@d7/framework": "^1.0.19",
    "@d7/http": "^1.0.19",
    "@d7/injector": "^1.0.19",
    "@d7/logger": "^1.0.19",
    "@d7/orm": "^1.0.19",
    "@d7/rpc": "^1.0.19",
    "@d7/type": "^1.0.19",
    "@types/node": "^22.13.1",
    "rxjs": "~7.8.0"
  },
  "jest": {
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    },
    "moduleNameMapper": {
      "(.+)\\.js": "$1"
    },
    "testMatch": [
      "**/tests/**/*.spec.ts"
    ]
  }
}
