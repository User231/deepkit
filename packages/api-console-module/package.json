{
  "name": "@deepkit/api-console-module",
  "version": "2.0.0",
  "description": "API Console",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "repository": "https://github.com/deepkit/deepkit-framework",
  "author": "Marc J. Schmidt <marc@marcjschmidt.de>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json",
    "test:node": "node --import @deepkit/run --test --test-force-exit 'tests/**/*.spec.ts'"
  },
  "peerDependencies": {
    "@deepkit/app": "^2.0.0",
    "@deepkit/broker": "^2.0.0",
    "@deepkit/bson": "^2.0.0",
    "@deepkit/core": "^2.0.0",
    "@deepkit/http": "^2.0.0",
    "@deepkit/injector": "^2.0.0",
    "@deepkit/logger": "^2.0.0",
    "@deepkit/rpc": "^2.0.0",
    "@deepkit/type": "^2.0.0"
  },
  "dependencies": {
    "@deepkit/api-console-api": "^2.0.0",
    "@deepkit/api-console-gui": "^2.0.0"
  },
  "devDependencies": {
    "@deepkit/app": "^2.0.0",
    "@deepkit/broker": "^2.0.0",
    "@deepkit/bson": "^2.0.0",
    "@deepkit/core": "^2.0.0",
    "@deepkit/http": "^2.0.0",
    "@deepkit/injector": "^2.0.0",
    "@deepkit/logger": "^2.0.0",
    "@deepkit/rpc": "^2.0.0",
    "@deepkit/type": "^2.0.0",
    "rxjs": "7.8.2"
  }
}
