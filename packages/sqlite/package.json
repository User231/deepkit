{
  "name": "@deepkit/sqlite",
  "version": "2.0.0",
  "description": "deepkit/orm SQLite adapter",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json",
    "test:node": "node --import @deepkit/run --test --test-force-exit 'tests/**/*.spec.ts'"
  },
  "repository": "https://github.com/deepkit/deepkit-framework",
  "author": "Marc J. Schmidt <marc@marcjschmidt.de>",
  "license": "MIT",
  "peerDependencies": {
    "@deepkit/core": "^2.0.0",
    "@deepkit/orm": "^2.0.0",
    "@deepkit/sql": "^2.0.0",
    "@deepkit/stopwatch": "^2.0.0",
    "@deepkit/type": "^2.0.0"
  },
  "dependencies": {
    "@types/better-sqlite3": "7.6.13",
    "better-sqlite3": "11.10.0",
    "sqlstring-sqlite": "0.1.1"
  },
  "devDependencies": {
    "@deepkit/core": "^2.0.0",
    "@deepkit/orm": "^2.0.0",
    "@deepkit/orm-integration": "^2.0.0",
    "@deepkit/sql": "^2.0.0",
    "@deepkit/stopwatch": "^2.0.0",
    "@deepkit/type": "^2.0.0"
  },
  "gitHead": "56081823b559bb68b77a8781957af5d9c2e019a7"
}
