{
  "name": "@deepkit/topsort",
  "version": "1.0.19",
  "description": "High-Performance topological sort / dependency resolver with optional grouping algorithm for Typescript",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json",
    "test:node": "node --import @deepkit/run --test 'tests/**/*.spec.ts'"
  },
  "repository": "https://github.com/deepkit/deepkit-framework",
  "author": "Marc J. Schmidt <marc@marcjschmidt.de>",
  "license": "MIT",
  "dependencies": {
    "@deepkit/core": "^1.0.1-alpha.153"
  },
  "gitHead": "56081823b559bb68b77a8781957af5d9c2e019a7"
}
