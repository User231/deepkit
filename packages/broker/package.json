{
  "name": "@deepkit/broker",
  "version": "1.0.19",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./test": {
      "types": "./tests/broker.spec.ts",
      "require": "./tests/broker.spec.ts",
      "default": "./tests/broker.spec.ts"
    }
  },
  "repository": "https://github.com/deepkit/deepkit-framework",
  "author": "Marc J. Schmidt <marc@marcjschmidt.de>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json",
    "test:node": "node --expose-gc --import @deepkit/run --test --test-force-exit 'tests/**/*.spec.ts'"
  },
  "dependencies": {
    "@lukeed/ms": "^2.0.1",
    "js-xxhash": "3.0.1"
  },
  "peerDependencies": {
    "@deepkit/bson": "^1.0.1",
    "@deepkit/core": "^1.0.1",
    "@deepkit/event": "^1.0.1",
    "@deepkit/injector": "^1.0.1",
    "@deepkit/rpc": "^1.0.1",
    "@deepkit/type": "^1.0.1",
    "rxjs": "*"
  },
  "devDependencies": {
    "@deepkit/bson": "^1.0.19",
    "@deepkit/core": "^1.0.19",
    "@deepkit/core-rxjs": "^1.0.19",
    "@deepkit/event": "^1.0.19",
    "@deepkit/injector": "^1.0.19",
    "@deepkit/rpc": "^1.0.19",
    "@deepkit/type": "^1.0.19",
    "rxjs": "*"
  },
  "gitHead": "56081823b559bb68b77a8781957af5d9c2e019a7"
}
