{
  "name": "@deepkit/broker",
  "version": "2.0.0",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./test": {
      "types": "./tests/broker.spec.ts",
      "require": "./tests/broker.spec.ts",
      "default": "./tests/broker.spec.ts"
    }
  },
  "repository": "https://github.com/deepkit/deepkit-framework",
  "author": "Marc J. Schmidt <marc@marcjschmidt.de>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json",
    "test:node": "node --expose-gc --import @deepkit/run --test --test-force-exit 'tests/**/*.spec.ts'"
  },
  "dependencies": {
    "@lukeed/ms": "2.0.2",
    "js-xxhash": "3.0.1"
  },
  "peerDependencies": {
    "@deepkit/bson": "^2.0.0",
    "@deepkit/core": "^2.0.0",
    "@deepkit/event": "^2.0.0",
    "@deepkit/injector": "^2.0.0",
    "@deepkit/rpc": "^2.0.0",
    "@deepkit/type": "^2.0.0",
    "rxjs": "*"
  },
  "devDependencies": {
    "@deepkit/bson": "^2.0.0",
    "@deepkit/core": "^2.0.0",
    "@deepkit/core-rxjs": "^2.0.0",
    "@deepkit/event": "^2.0.0",
    "@deepkit/injector": "^2.0.0",
    "@deepkit/rpc": "^2.0.0",
    "@deepkit/type": "^2.0.0",
    "rxjs": "7.8.2"
  },
  "gitHead": "56081823b559bb68b77a8781957af5d9c2e019a7"
}
