{
  "name": "@deepkit/mongo",
  "version": "2.0.0",
  "description": "Deepkit ORM MongoDB adapter",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json",
    "test:node": "node --expose-gc --import @deepkit/run --test --test-force-exit 'tests/**/*.spec.ts'"
  },
  "repository": "https://github.com/deepkit/deepkit-framework",
  "author": "Marc J. Schmidt <marc@marcjschmidt.de>",
  "license": "MIT",
  "peerDependencies": {
    "@deepkit/bson": "^2.0.0",
    "@deepkit/core": "^2.0.0",
    "@deepkit/orm": "^2.0.0",
    "@deepkit/type": "^2.0.0"
  },
  "dependencies": {
    "saslprep-patch": "1.0.6"
  },
  "devDependencies": {
    "@deepkit/bson": "^2.0.0",
    "@deepkit/core": "^2.0.0",
    "@deepkit/orm": "^2.0.0",
    "@deepkit/orm-integration": "^2.0.0",
    "@deepkit/type": "^2.0.0",
    "@types/mongodb": "3.6.20",
    "@types/node": "22.19.21",
    "mongodb": "6.21.0"
  },
  "gitHead": "56081823b559bb68b77a8781957af5d9c2e019a7"
}
