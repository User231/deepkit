{
  "name": "@d7/template",
  "version": "1.0.19",
  "description": "D7 template engine based on TSX",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/cjs/jsx-runtime.d.ts",
      "require": "./dist/cjs/jsx-runtime.js",
      "default": "./dist/esm/jsx-runtime.js"
    }
  },
  "repository": "https://github.com/marcj/d7",
  "author": "Marc J. Schmidt <marc@marcjschmidt.de>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json"
  },
  "peerDependencies": {
    "@d7/core": "^1.0.1",
    "@d7/injector": "^1.0.1",
    "@d7/stopwatch": "^1.0.1",
    "@d7/type": "^1.0.1"
  },
  "dependencies": {
    "@types/estree": "^0.0.45",
    "abstract-syntax-tree": "^2.9.4"
  },
  "devDependencies": {
    "@d7/core": "^1.0.19",
    "@d7/injector": "^1.0.19",
    "@d7/stopwatch": "^1.0.19",
    "@d7/type": "^1.0.19"
  },
  "jest": {
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": "<rootDir>/tsconfig.spec.json"
        }
      ]
    },
    "moduleNameMapper": {
      "(.+)\\.js": "$1"
    },
    "testMatch": [
      "**/tests/**/*.spec.ts",
      "**/tests/**/*.spec.tsx"
    ]
  },
  "gitHead": "56081823b559bb68b77a8781957af5d9c2e019a7"
}
