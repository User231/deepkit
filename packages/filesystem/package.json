{
  "name": "@deepkit/filesystem",
  "version": "1.0.19",
  "description": "Filesystem abstraction Deepkit",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./test": {
      "types": "./tests/filesystem.spec.ts",
      "require": "./tests/filesystem.spec.ts",
      "default": "./tests/filesystem.spec.ts"
    }
  },
  "repository": "https://github.com/deepkit/deepkit-framework",
  "author": "Marc J. Schmidt <marc@marcjschmidt.de>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json",
    "test:node": "node --import @deepkit/run --test --test-force-exit 'tests/**/*.spec.ts'"
  },
  "peerDependencies": {
    "@deepkit/core": "^1.0.1"
  },
  "devDependencies": {
    "@deepkit/core": "^1.0.19"
  }
}
