{
  "name": "@deepkit/type",
  "version": "1.0.19",
  "description": "@deepkit/type, the fastest universal TypeScript serializer and validator with JIT engine for frontend, backend, http-transport, RPC, and database, with built-in validations, for Browser/NodeJS.",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json",
    "test:node": "node --import @deepkit/run --test 'tests/**/*.spec.ts'"
  },
  "repository": "https://github.com/deepkit/deepkit-framework",
  "author": "Marc J. Schmidt <marc@marcjschmidt.de>",
  "license": "MIT",
  "peerDependencies": {
    "@deepkit/core": "^1.0.1"
  },
  "dependencies": {
    "@deepkit/type-spec": "^1.0.19",
    "@types/uuid": "8.3.4",
    "buffer": "5.7.1",
    "uuid": "8.3.2"
  },
  "devDependencies": {
    "@deepkit/core": "^1.0.19",
    "@deepkit/type-compiler": "^1.0.19",
    "@types/lz-string": "1.5.0",
    "@types/node": "22.19.21",
    "@typescript/vfs": "1.6.4",
    "lz-string": "1.5.0"
  },
  "gitHead": "56081823b559bb68b77a8781957af5d9c2e019a7"
}
