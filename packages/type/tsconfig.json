{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist/cjs",
    "types": ["uuid", "lz-string", "node"]
  },
  "reflection": [
    "src/reflection/**/*.ts",
    "src/mixin.ts",
    "src/validator.ts",
    "src/serializer-facade.ts",
    "src/typeguard.ts",
    "src/change-detection.ts",
    "src/decorator.ts",
    "benchmarks/**/*.ts"
  ],
  "include": ["src", "index.ts"],
  "references": [
    {
      "path": "../type-spec/tsconfig.json"
    },
    {
      "path": "../core/tsconfig.json"
    },
    {
      "path": "../type-compiler/tsconfig.json"
    }
  ]
}
