    "@deepkit/core": "^2.0.0",
    "@deepkit/core-rxjs": "^2.0.0",
    "@deepkit/event": "^2.0.0",
    "@deepkit/framework": "^2.0.0",
    "@deepkit/http": "^2.0.0",
    "@deepkit/injector": "^2.0.0",
    "@deepkit/logger": "^2.0.0",
    "@deepkit/orm": "^2.0.0",
    "@deepkit/rpc": "^2.0.0",
    "@deepkit/rpc-tcp": "^2.0.0",
    "@deepkit/sql": "^2.0.0",
    "@deepkit/sqlite": "^2.0.0",
    "@deepkit/stopwatch": "^2.0.0",
    "@deepkit/template": "^2.0.0",
