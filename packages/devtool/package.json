{
  "name": "@deepkit/devtool",
  "version": "2.0.0",
  "description": "Deepkit chrome devtool",
  "scripts": {
    "ng": "ng",
    "start": "NODE_OPTIONS=--preserve-symlinks ng serve",
    "build": "rm -rf .angular && NODE_OPTIONS=--preserve-symlinks ng build --configuration production && zip -r dist.zip dist",
    "build:dev": "NODE_OPTIONS=--preserve-symlinks ng build",
    "watch": "NODE_OPTIONS=--preserve-symlinks ng build --watch",
    "test": "NODE_OPTIONS=--preserve-symlinks ng test",
    "lint": "NODE_OPTIONS=--preserve-symlinks ng lint",
    "e2e": "NODE_OPTIONS=--preserve-symlinks ng e2e"
  },
  "repository": "https://github.com/deepkit/deepkit-framework",
  "author": "Marc J. Schmidt <marc@marcjschmidt.de>",
  "license": "MIT",
  "private": true,
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.28",
    "@angular/animations": "20.3.25",
    "@angular/cdk": "20.2.14",
    "@angular/cli": "20.3.28",
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/compiler-cli": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/forms": "20.3.25",
    "@angular/platform-browser": "20.3.25",
    "@angular/platform-browser-dynamic": "20.3.25",
    "@angular/router": "20.3.25",
    "@deepkit/bson": "^2.0.0",
    "@deepkit/core": "^2.0.0",
    "@deepkit/core-rxjs": "^2.0.0",
    "@deepkit/desktop-ui": "^2.0.0",
    "@deepkit/event": "^2.0.0",
    "@deepkit/injector": "^2.0.0",
    "@deepkit/logger": "^2.0.0",
    "@deepkit/rpc": "^2.0.0",
    "@deepkit/stopwatch": "^2.0.0",
    "@deepkit/type": "^2.0.0",
    "@deepkit/type-compiler": "^2.0.0",
    "@deepkit/ui-library": "^2.0.0",
    "@types/jasmine": "4.6.6",
    "@types/marked": "4.3.2",
    "jasmine-core": "4.6.1",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "object-inspect": "1.13.4",
    "prismjs": "1.30.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "typescript": "5.8.3"
  }
}
