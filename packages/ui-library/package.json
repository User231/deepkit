{
  "name": "@deepkit/ui-library",
  "version": "2.0.0",
  "description": "Collection of utilities for Deepkit's graphical user interfaces",
  "repository": "https://github.com/deepkit/deepkit-framework",
  "author": "Marc J. Schmidt <marc@marcjschmidt.de>",
  "license": "MIT",
  "sideEffects": false,
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/fesm2022/deepkit-ui-library.mjs"
    }
  },
  "scripts": {
    "build": "rm -rf .angular && ng-packagr --config tsconfig.prod.json && rm dist/.npmignore",
    "watch": "ng-packagr --config tsconfig.prod.json --watch"
  },
  "peerDependencies": {
    "@angular/common": "20.0.4",
    "@angular/core": "20.3.16",
    "@angular/forms": "20.0.4",
    "@deepkit/core": "^2.0.0",
    "@deepkit/desktop-ui": "^2.0.0",
    "@deepkit/rpc": "^2.0.0",
    "@deepkit/type": "^2.0.0"
  },
  "dependencies": {
    "prismjs": "1.30.0"
  },
  "devDependencies": {
    "@deepkit/core": "^2.0.0",
    "@deepkit/desktop-ui": "^2.0.0",
    "@deepkit/rpc": "^2.0.0",
    "@deepkit/type": "^2.0.0",
    "@types/prismjs": "1.26.6",
    "ng-packagr": "20.3.2",
    "ngxtension": "5.2.0",
    "rxjs": "7.8.2"
  }
}
