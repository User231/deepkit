{
  "name": "@deepkit/bson",
  "version": "2.0.0",
  "description": "Deepkit BSON parser",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json",
    "test:node": "node --import @deepkit/run --test 'tests/**/*.spec.ts'"
  },
  "repository": "https://github.com/deepkit/deepkit-framework",
  "author": "Marc J. Schmidt <marc@marcjschmidt.de>",
  "license": "MIT",
  "peerDependencies": {
    "@deepkit/core": "^2.0.0",
    "@deepkit/type": "^2.0.0"
  },
  "devDependencies": {
    "@deepkit/core": "^2.0.0",
    "@deepkit/type": "^2.0.0",
    "@types/node": "22.19.21",
    "bson": "7.2.0"
  },
  "gitHead": "56081823b559bb68b77a8781957af5d9c2e019a7"
}
