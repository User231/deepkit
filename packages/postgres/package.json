{
  "name": "@deepkit/postgres",
  "version": "2.0.0",
  "description": "deepkit/orm PostgreSQL adapter",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json",
    "test:node": "node --import @deepkit/run --test --test-force-exit 'tests/**/*.spec.ts'"
  },
  "repository": "https://github.com/deepkit/deepkit-framework",
  "author": "Marc J. Schmidt <marc@marcjschmidt.de>",
  "license": "MIT",
  "peerDependencies": {
    "@deepkit/core": "^2.0.0",
    "@deepkit/orm": "^2.0.0",
    "@deepkit/sql": "^2.0.0",
    "@deepkit/stopwatch": "^2.0.0",
    "@deepkit/type": "^2.0.0"
  },
  "dependencies": {
    "@types/pg": "7.14.11",
    "pg": "8.21.0",
    "sqlstring": "2.3.3"
  },
  "devDependencies": {
    "@deepkit/core": "^2.0.0",
    "@deepkit/orm": "^2.0.0",
    "@deepkit/sql": "^2.0.0",
    "@deepkit/stopwatch": "^2.0.0",
    "@deepkit/type": "^2.0.0",
    "@types/sqlstring": "2.3.2"
  },
  "gitHead": "56081823b559bb68b77a8781957af5d9c2e019a7"
}
