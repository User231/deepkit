{
  "name": "@deepkit/benchmarks",
  "version": "1.0.0",
  "private": true,
  "description": "Benchmark infrastructure for Deepkit Framework",
  "main": "dist/runner.js",
  "types": "dist/runner.d.ts",
  "scripts": {
    "build": "../node_modules/.bin/tsc",
    "benchmark": "node --preserve-symlinks -r ../node_modules/ts-node/register src/runner.ts",
    "benchmark:comparison": "npm run benchmark -- -d src/benchmarks/comparison",
    "benchmark:debug": "npm run benchmark -- -d src/benchmarks/debug",
    "benchmark:all": "npm run benchmark -- -d src/benchmarks",
    "benchmark:json": "npm run benchmark -- -j results.json",
    "benchmark:compare": "npm run benchmark -- --compare-baseline",
    "benchmark:save-baseline": "npm run benchmark -- --save-baseline",
    "report": "node --preserve-symlinks -r ../node_modules/ts-node/register src/generate-report.ts"
  },
  "dependencies": {
    "@deepkit/app": "file:../packages/app",
    "@deepkit/bson": "file:../packages/bson",
    "@deepkit/core": "file:../packages/core",
    "@deepkit/event": "file:../packages/event",
    "@deepkit/injector": "file:../packages/injector",
    "@deepkit/logger": "file:../packages/logger",
    "@deepkit/orm": "file:../packages/orm",
    "@deepkit/sql": "file:../packages/sql",
    "@deepkit/sqlite": "file:../packages/sqlite",
    "@deepkit/type": "file:../packages/type",
    "@deepkit/type-compiler": "file:../packages/type-compiler",
    "bson": "^6.0.0",
    "class-transformer": "^0.5.1",
    "glob": "^10.3.10",
    "reflect-metadata": "^0.2.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0"
  }
}
