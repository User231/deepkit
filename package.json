{
  "name": "root",
  "repository": "https://github.com/deepkit/deepkit-framework",
  "author": "Marc J. Schmidt <marc@marcjschmidt.de>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "test": "node --expose-gc --import @deepkit/run --test --test-force-exit 'packages/*/tests/**/*.spec.ts' 'packages/*/tests/**/*.spec.tsx' 'packages/create-app/files/tests/**/*.spec.ts'",
    "test:node": "node --expose-gc --import @deepkit/run --test --test-force-exit 'packages/*/tests/**/*.spec.ts' 'packages/*/tests/**/*.spec.tsx' 'packages/create-app/files/tests/**/*.spec.ts'",
    "test:lerna": "lerna run test:node --concurrency 1 --no-bail",
    "test:mongo-cluster": "MONGO_CLUSTER_TESTS=1 node --expose-gc --import @deepkit/run --test --test-force-exit --test-concurrency=1 'packages/mongo/tests/replica.spec.ts' 'packages/mongo/tests/client/mong-env.spec.ts'",
    "build": "tsc --build tsconfig.json && tsc --build tsconfig.esm.json && lerna run build",
    "build:esm": "tsc --build tsconfig.esm.json",
    "tsc": "tsc --build",
    "typecheck": "tsc --build",
    "postinstall": "lefthook install && sh install-compiler.sh",
    "tsc-watch": "tsc --build --watch tsconfig.json",
    "tsc-watch:esm": "tsc --build --watch tsconfig.esm.json",
    "clean:all": "npm run clean && npm run clean:modules && npm run clean:lock",
    "clean": "find packages/*/dist/* ! -name 'package.json' -type f -exec rm -f {} +; rm -rf packages/*/.angular; rm -rf website/.angular; npm run postinstall",
    "clean:modules": "rm -rf packages/*/node_modules; rm -rf node_modules",
    "clean:lock": "rm -rf packages/*/package-lock.json; rm -rf package-lock.json",
    "docs": "rm -rf docs && node --max-old-space-size=12096 node_modules/.bin/typedoc --options typedoc.js packages/*/index.ts",
    "publish": "lerna publish --no-private patch",
    "publish-force": "npm run build && lerna publish --no-private --force-publish",
    "check:circular": "madge --extensions ts --warning --circular",
    "publish-website": "heroku container:push web && heroku container:release web"
  },
  "workspaces": [
    "website",
    "packages/*",
    "!packages/fs",
    "!packages/orm-browser-example",
    "!packages/framework-examples"
  ],
  "devDependencies": {
    "@commitlint/config-conventional": "18.6.3",
    "@commitlint/config-lerna-scopes": "18.6.1",
    "@deepkit/core": "^1.0.1",
    "@jest/globals": "29.7.0",
    "@trivago/prettier-plugin-sort-imports": "4.3.0",
    "@types/node": "22.19.21",
    "cloc": "2.11.0",
    "codecov": "3.8.3",
    "commitlint": "18.6.1",
    "coveralls": "3.1.1",
    "jest": "29.7.0",
    "lefthook": "1.13.6",
    "lerna": "8.2.4",
    "madge": "8.0.0",
    "prettier": "3.8.4",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typedoc": "0.23.28",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">= 20.0.0"
  },
  "_comment_jest": "Jest is retained ONLY for the docs `website` (Angular `TestBed` + tsconfig path-alias tests that need a DOM/Angular test harness); it runs from `website/` via website/jest.config.js. Every package — including @deepkit/template (.spec.tsx) — runs on node:test via the root `test` script (node --import @deepkit/run --test). There is intentionally no root-level jest config.",
  "packageManager": "yarn@4.17.0"
}
